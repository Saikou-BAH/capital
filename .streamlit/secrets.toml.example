# ──────────────────────────────────────────────────────────────────────────────
# secrets.toml — Pour Streamlit Community Cloud
# ──────────────────────────────────────────────────────────────────────────────
# Dans Streamlit Cloud : allez dans les Settings de votre app > Secrets
# et collez le contenu ci-dessous (sans les commentaires), rempli avec vos valeurs.
#
# En local, vous pouvez aussi créer .streamlit/secrets.toml (non commité).

spreadsheet_id = "votre_spreadsheet_id_ici"

[gcp_service_account]
type                        = "service_account"
project_id                  = "votre-projet-gcp"
private_key_id              = "votre_key_id"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
client_email                = "votre-compte@votre-projet.iam.gserviceaccount.com"
client_id                   = "123456789"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "https://www.googleapis.com/robot/v1/metadata/x509/..."
