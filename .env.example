# ──────────────────────────────────────────────────────────────────────────────
# Suivi Capital Familial — Variables d'environnement
# ──────────────────────────────────────────────────────────────────────────────
# Copiez ce fichier en .env et remplissez vos valeurs.
# Le fichier .env ne doit JAMAIS être commité sur GitHub.

# ── Backend de stockage ──────────────────────────────────────────────────────
# "csv"    → stockage local dans data/*.csv (défaut, aucune config requise)
# "sheets" → Google Sheets (nécessite les variables ci-dessous)
BACKEND=csv

# ── Mode applicatif ──────────────────────────────────────────────────────────
# Local/admin : laissez READ_ONLY=false pour saisir depuis l'interface.
# Production : mettez READ_ONLY=true ou APP_MODE=production pour bloquer toute écriture.
READ_ONLY=false
APP_MODE=local

# ── Google Sheets (uniquement si BACKEND=sheets) ──────────────────────────────
# Chemin vers votre fichier credentials Google Service Account (JSON)
GOOGLE_CREDENTIALS_PATH=credentials.json

# ID du Google Spreadsheet (dans l'URL : /spreadsheets/d/VOTRE_ID/edit)
SPREADSHEET_ID=votre_spreadsheet_id_ici
